# BullMQ / Redis
# Local Redis:
REDIS_URL=redis://localhost:6379
# Railway Redis injects the same variable in production:
# REDIS_URL=${{Redis.REDIS_URL}}
# Alternative managed Redis setup:
# REDIS_HOST=your-db.upstash.io
# REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password
# REDIS_TLS=true
# Optional Upstash fallback if you only have the REST endpoint/token:
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-redis-password

# AWS / S3
AWS_REGION=eu-north-1
S3_BUCKET=umthethx-files
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY

# Web / API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Worker behavior
MAX_DOCUMENT_PAGES=30
LIBRETRANSLATE_URL=http://localhost:5000
LIBRETRANSLATE_API_KEY=
LIBRETRANSLATE_TARGET_LANG=en
LIBRETRANSLATE_SOURCE_LANG=auto
TESSERACT_LANG=eng

# Local-only binary overrides. Leave these unset on Railway.
# PYTHON_BIN=/path/to/python
# TESSERACT_BIN=/path/to/tesseract
# IMAGEMAGICK_BIN=/path/to/magick
# LIBREOFFICE_BIN=/path/to/soffice
