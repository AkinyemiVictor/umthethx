# BullMQ / Redis
# Local Redis:
REDIS_URL=redis://localhost:6379
# Upstash or other managed Redis:
# REDIS_HOST=your-db.upstash.io
# REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password
# REDIS_TLS=true
# Optional fallback if you only have the Upstash REST endpoint/token:
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-redis-password
